### 5. Update cart item quantity
PUT http://localhost:8080/api/v1/cart/items/1
Authorization: Bearer eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiJqb2huQGV4YW1wbGUuY29tIiwiaWF0IjoxNzc5MzA4MjA1LCJleHAiOjE3NzkzOTQ2MDV9.si2xemO3MFqx7Lo6ww2-meBA8lJdmGHaODaTqdg1RN-P2ice_tzALfp5iahIeWMMwGC8sk8XvaAg8d1zgSTXRA
Content-Type: application/json

{
  "quantity": 5
}

### 6. Remove cart item
DELETE http://localhost:8080/api/v1/cart/items/1
Authorization: Bearer eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiJqb2huQGV4YW1wbGUuY29tIiwiaWF0IjoxNzc5MzA4MjA1LCJleHAiOjE3NzkzOTQ2MDV9.si2xemO3MFqx7Lo6ww2-meBA8lJdmGHaODaTqdg1RN-P2ice_tzALfp5iahIeWMMwGC8sk8XvaAg8d1zgSTXRA

